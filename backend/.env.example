PORT=3001
NODE_ENV=development

# Clerk Dashboard → Webhooks → Signing secret (Svix). Required for POST /auth/webhook in production.
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Optional: allow POST /kyc/secure-download-url for legacy keys under kyc-uploads/ (not tenant-prefixed). Prefer tenant-scoped uploads only.
# KYC_STORAGE_ALLOW_LEGACY_KYC_UPLOADS_DOWNLOAD=1

# Local R2 scripts (testUpload.js / testR2.js) tenant folder under users/{id}/...
# SCRIPT_STORAGE_TENANT_ID=your_clerk_user_id

# Behind reverse proxy (Render): forwarded client IP (`X-Forwarded-For`). In production unset = trust first hop.
# TRUST_PROXY=1

# Global IP rate limit (all routes; 15-minute window)
RATE_LIMIT_MAX=100

# KYC routes (after auth): burst window in ms (default 15m)
# RATE_LIMIT_KYC_WINDOW_MS=900000

# Per-plan default max requests per tenant bucket per window (API keys = separate bucket per key; Clerk/capture = per user id)
RATE_LIMIT_KYC_BURST_FREE=120
RATE_LIMIT_KYC_BURST_GROWTH=600
RATE_LIMIT_KYC_BURST_ENTERPRISE=2500

# Shared per-client-IP ceiling on KYC routes (same window); mitigates many keys behind one NAT
RATE_LIMIT_KYC_PER_IP=800

# Optional JSON map of IP → numeric cap for that IP (e.g. stricter abuse targets)
# RATE_LIMIT_KYC_IP_OVERRIDES={"203.0.113.50":100}

# Mongo policy cache for burst limits (ms); 0 disables caching
# RATE_LIMIT_KYC_POLICY_CACHE_MS=45000

# Groq chat completion deadline (AbortSignal.timeout; ms)
GROQ_TIMEOUT_MS=120000

# R2 HEAD object existence check during preflight before LLM (ms)
R2_HEAD_TIMEOUT_MS=8000

# Max image object size enforced at pre-verify HEAD (bytes; default 10 MiB)
KYC_MAX_IMAGE_BYTES=10485760

# When 1, DELETE /admin/verifications/:id also deletes R2 object keys referenced on the profile and latest validations (best-effort).
# ADMIN_DELETE_PURGE_OBJECTS=1

# Clerk user id of the operator who owns SPA verifications when end-users sign in with a different Clerk id (sets Profile.merchantUserId vs Profile.userId).
# APP_DEFAULT_MERCHANT_CLERK_ID=user_xxxxx

# Single-tenant only: LIST + STATS endpoints return all Mongo profiles (`{}` query). Deletes/replays still scoped to tenant. Do NOT enable with multiple Clerk tenants sharing one DB.
# ADMIN_DASHBOARD_LIST_ALL_PROFILES=1

# Comma-separated MIME allowlist for presign + HEAD content-type check (optional)
# KYC_ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp,image/gif

# Preflight byte sniff (needs R2 Range GET). `0` disables each check.
# KYC_MIN_IMAGE_DIMENSION=320
# KYC_MIN_MEGAPIXELS=0.2

# TTL on WebhookDelivery.createdAt in Mongo (seconds, min 60). Omit to keep rows indefinitely.
# WEBHOOK_DELIVERY_TTL_SECONDS=7776000
# WEBHOOK_DELIVERY_TIMEOUT_MS=8000
# WEBHOOK_DELIVERY_MAX_ATTEMPTS=3
# WEBHOOK_DELIVERY_BACKOFF_MS_2=500
# WEBHOOK_DELIVERY_BACKOFF_MS_3=2000

# Lifecycle scheduler ticks (truthy env enables interval jobs). Default R2/Mongo ticks are informational / gated purge — see docs/RETENTION_DECISION_CHECKLIST.md
# R2_LIFECYCLE_CRON=1
# R2_LIFECYCLE_INTERVAL_MINUTES=60
# MONGO_LIFECYCLE_CRON=1
# MONGO_LIFECYCLE_INTERVAL_MINUTES=60
# When MONGO_LIFECYCLE_CRON is set, optional MONGO_PROFILE_AGE_DAYS enables a read-only terminal-profile age report (see below).

# Opt-in R2 age purge (requires docs/RETENTION_DECISION_CHECKLIST.md sign-off); min age floor enforced in code (7d). Per-tick deletion cap default 500.
# Objects linked on profiles with legalHold=true or unresolved manual review (queued) are skipped automatically.
# R2_LIFECYCLE_PURGE_ENABLED=1
# R2_RETENTION_MIN_AGE_DAYS=90
# R2_LIFECYCLE_PREFIXES=kyc-uploads/,other-prefix/
# R2_LIFECYCLE_PREFIX=kyc-uploads/
# R2_LIFECYCLE_PURGE_MAX_KEYS_PER_TICK=500

# Read-only: log counts of terminal profiles older than N days (no deletes). Destructive Mongo TTL/archival still gated on retention sign-off.
# MONGO_PROFILE_AGE_DAYS=180

# End-user session read token (`X-Verification-Session`). Min 16 chars; keep server-only.
# VERIFICATION_CAPTURE_TOKEN_SECRET=
# VERIFICATION_CAPTURE_TTL_SECONDS=900
# VERIFICATION_CAPTURE_TTL_MAX_SECONDS=86400

# Manual review queue deadline when enqueued (hours, max 720).
# MANUAL_REVIEW_SLA_HOURS=72

# CI-only: `id` or `selfie` skips Groq — never set in production.
# VERIFICATION_PIPELINE_FIXTURE=id
