PORT=3001
NODE_ENV=development

# Behind reverse proxy (Render): forwarded client IP (`X-Forwarded-For`). In production unset = trust first hop.
# TRUST_PROXY=1

# Global IP rate limit (requests per window below)
RATE_LIMIT_MAX=100

# Per-window cap for requests authenticated with X-API-Key (separate bucket per key)
RATE_LIMIT_API_KEY_MAX=1000

# Groq chat completion deadline (AbortSignal.timeout; ms)
GROQ_TIMEOUT_MS=120000

# R2 HEAD object existence check during preflight before LLM (ms)
R2_HEAD_TIMEOUT_MS=8000

# Max image object size enforced at pre-verify HEAD (bytes; default 10 MiB)
KYC_MAX_IMAGE_BYTES=10485760

# When 1, DELETE /admin/verifications/:id also deletes R2 object keys referenced on the profile and latest validations (best-effort).
# ADMIN_DELETE_PURGE_OBJECTS=1

# Comma-separated MIME allowlist for presign + HEAD content-type check (optional)
# KYC_ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp,image/gif

# Preflight byte sniff (needs R2 Range GET). `0` disables each check.
# KYC_MIN_IMAGE_DIMENSION=320
# KYC_MIN_MEGAPIXELS=0.2

# TTL on WebhookDelivery.createdAt in Mongo (seconds, min 60). Omit to keep rows indefinitely.
# WEBHOOK_DELIVERY_TTL_SECONDS=7776000

# End-user session read token (`X-Verification-Session`). Min 16 chars; keep server-only.
# VERIFICATION_CAPTURE_TOKEN_SECRET=
# VERIFICATION_CAPTURE_TTL_SECONDS=900
# VERIFICATION_CAPTURE_TTL_MAX_SECONDS=86400

# Manual review queue deadline when enqueued (hours, max 720).
# MANUAL_REVIEW_SLA_HOURS=72

# CI-only: `id` or `selfie` skips Groq — never set in production.
# VERIFICATION_PIPELINE_FIXTURE=id
